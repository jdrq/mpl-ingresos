<style type="text/css">
	
body
{
	font-weight: normal;
	font-size: 0.7em;
	word-spacing: normal;
	text-transform: none;
	font-family: Arial, Verdana, Helvetica, sans-serif;
	letter-spacing: normal;
	background-color: #ffffff;
	padding: 0px;
	margin: 0px;
	height: 100%;
	left: 0px;
	right: 0px;
	border: 0px;
}

/* Panel Historial */
#PnlHistory
{    
    background-color: #ffffff;
}

.History
{
    width: 100%;
    margin: 0 auto;
    border-collapse: collapse;
    background-color: #ffffff;
    border: solid 1px #dddddd;
}

.History tr
{
    height: 20px;
}

.History tr.alt
{
}

.History td
{
    border-left: solid 1px #dddddd;
    border-right: solid 1px #dddddd;
}
/* Panel Historial - Fin */

/* Panel Datos */
#PnlData
{
    background-color: #ffffff;
}

.MapTable
{
    background-color: #3a6ea5;
    color: #ffffff;
    border-collapse: collapse;
    border-width: 0px;
}

.MapTable tr
{
    height: 18px;
}

.MapTable td
{
    border: solid 1px #dddddd;
    text-align: center;
    font-weight: bold;
}

.Data
{    
    width: 100%;
    border-collapse: collapse;
    border-width: 0px;
}

.Data tr
{
    cursor: pointer;    
    height: 22px;
    text-align: right;
}

.Data tr.alt
{
}

.Data tr.More
{
    text-align: left;
    height: auto;
    background-color: #f1f1f1;    
}

.Data tr.More td
{
    padding-left: 4px;
}

.Data td
{
    border: solid 1px #dddddd;
}
/* Panel Datos - Fin */

/* Cabecera */
#hd
{
    font-size: 8pt;   
}

#hd .title
{
    font-size: 12pt;
    font-weight: bold;
    font-family: Verdana;
}

#hd .subtitle
{
    font-size: 8pt;
    font-family: Verdana;
}

#hd .fecha
{
    font-size: 8pt;
}

#hd span.value
{
    font-size: 10pt;
}

/* Cabecera - End */
</style><body>
